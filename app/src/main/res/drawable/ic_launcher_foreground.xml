<?xml version="1.0" encoding="utf-8"?>
<!--
  GlyphMaps launcher icon foreground.

  An up-chevron rendered as Glyph-Matrix dots: the same warm-glow arrow the
  app lights on the back of the phone and shows in the in-app wordmark. Five
  bright head dots (tip + two inner + two outer arms) in warm white #FFE9B5,
  with a three-dot shaft trailing dimmer behind — exactly like the LED head
  (full) and tail (~62%) the matrix renders.

  Sized for the adaptive-icon safe zone: every dot's bounding circle stays
  within ~29 units of the (54,54) centre, comfortably inside the 33-unit
  visible radius that circular launchers crop to. Each glyph is a radius-5.5
  circle drawn with two arcs.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Head: chevron (tip + inner arms + outer arms), full warm glow. -->
    <path
        android:fillColor="#FFE9B5"
        android:pathData="
            M48.5,33 a5.5,5.5 0 1,0 11,0 a5.5,5.5 0 1,0 -11,0 z
            M37.5,43 a5.5,5.5 0 1,0 11,0 a5.5,5.5 0 1,0 -11,0 z
            M59.5,43 a5.5,5.5 0 1,0 11,0 a5.5,5.5 0 1,0 -11,0 z
            M26.5,53 a5.5,5.5 0 1,0 11,0 a5.5,5.5 0 1,0 -11,0 z
            M70.5,53 a5.5,5.5 0 1,0 11,0 a5.5,5.5 0 1,0 -11,0 z" />

    <!-- Tail: three-dot shaft, dimmed (matches the LED tail brightness). -->
    <path
        android:fillColor="#FFE9B5"
        android:fillAlpha="0.62"
        android:pathData="
            M48.5,53 a5.5,5.5 0 1,0 11,0 a5.5,5.5 0 1,0 -11,0 z
            M48.5,65 a5.5,5.5 0 1,0 11,0 a5.5,5.5 0 1,0 -11,0 z
            M48.5,77 a5.5,5.5 0 1,0 11,0 a5.5,5.5 0 1,0 -11,0 z" />
</vector>
